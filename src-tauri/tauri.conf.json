{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "SDV",
  "version": "0.80.3",
  "identifier": "com.gonnector.sdv",
  "build": {
    "frontendDist": "../dist-tauri",
    "devUrl": "http://localhost:3299",
    "beforeDevCommand": "node server.js --no-open --port 3299",
    "beforeBuildCommand": "npm run build:frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "SDV — Simple Doc Viewer",
        "width": 1280,
        "height": 860,
        "minWidth": 700,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      { "ext": ["md"], "name": "Markdown", "description": "Markdown document", "role": "Viewer" },
      { "ext": ["pdf"], "name": "PDF", "description": "PDF document", "role": "Viewer" }
    ]
  }
}
